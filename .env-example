# ambiente
AMBIENTE=producao
DEBUG=false

# API
API_TITULO=Nexus - Gerador de Relatórios
API_VERSAO=0.1.0

# banco interno do Nexus (PostgreSQL externo)
# Formato: postgresql+psycopg://usuario:senha@host:porta/banco
DATABASE_URL=postgresql+psycopg://nexus_admin:SENHA@192.168.1.X:5432/nexus

# Chave de autenticação da API (obrigatória em produção)
# Envie no header: X-Api-Key: <valor>
# Se vazio, auth desabilitada (só use assim em desenvolvimento)
API_KEY=GERE_UMA_CHAVE_FORTE_AQUI

# Chave de criptografia para senhas das conexões externas
# Gere uma nova com: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# ATENÇÃO: nunca mude essa chave em produção — as senhas do BD ficam ilegíveis
CHAVE_CRIPTOGRAFIA=GERE_UMA_NOVA_CHAVE_AQUI

# Active Directory (opcional — remova ou deixe em branco se não usar AD)
AD_SERVIDOR=ldap://192.168.1.5
AD_PORTA=389
AD_USAR_TLS=false
AD_BIND_USER=nexus-sync@empresa.com
AD_BIND_PASSWORD=SENHA_DO_USUARIO_DE_SERVICO
AD_OU=OU=Funcionarios,DC=empresa,DC=com
